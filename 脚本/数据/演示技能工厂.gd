extends RefCounted
class_name 演示技能工厂

static func 创建前排英雄状态(编号: StringName, 敏捷值: float) -> 英雄战役状态:
	var 普通攻击: 技能定义 = 创建技能定义(&"普通攻击", "基础的单体攻击，不附带额外效果。", [1, 2, 3, 4], [1, 2, 3, 4], 目标阵营类型.枚举.敌方单体, [创建伤害效果(1.0)], 0, true, ["基础攻击", "单体", "近战"])
	var 斩击: 技能定义 = 创建技能定义(&"斩击", "稳定的前排单体攻击，适合处理敌方前列。", [1, 2], [1, 2], 目标阵营类型.枚举.敌方单体, [创建伤害效果(1.15)], 0, false, ["输出", "近战", "单体"])
	var 破阵猛击: 技能定义 = 创建技能定义(&"破阵猛击", "猛击前排敌人并将其向后击退 1 格。", [1, 2], [1, 2], 目标阵营类型.枚举.敌方单体, [创建伤害效果(0.9), 创建位移效果(1)], 2, false, ["输出", "位移", "前排"])
	var 压迫怒吼: 技能定义 = 创建技能定义(&"压迫怒吼", "震慑敌方单体，造成额外压力。", [1, 2, 3], [1, 2, 3, 4], 目标阵营类型.枚举.敌方单体, [创建压力效果(12)], 4, false, ["压制", "精神", "单体"], 1)
	var 整备呼吸: 技能定义 = 创建技能定义(&"整备呼吸", "短暂整备，自我恢复少量生命。", [1, 2], [1, 2, 3, 4], 目标阵营类型.枚举.自身, [创建治疗效果(0.55)], 3, false, ["恢复", "自疗"])
	return _创建英雄状态(编号, 敏捷值, 6.0, 3.0, [普通攻击, 斩击, 破阵猛击, 压迫怒吼, 整备呼吸])


static func 创建后排英雄状态(编号: StringName, 敏捷值: float) -> 英雄战役状态:
	var 普通攻击: 技能定义 = 创建技能定义(&"普通攻击", "基础的单体攻击，不附带额外效果。", [1, 2, 3, 4], [1, 2, 3, 4], 目标阵营类型.枚举.敌方单体, [创建伤害效果(1.0)], 0, true, ["基础攻击", "单体", "远程"])
	var 精准射击: 技能定义 = 创建技能定义(&"精准射击", "后排主力输出，对中后排敌人造成更高伤害。", [2, 3, 4], [2, 3, 4], 目标阵营类型.枚举.敌方单体, [创建伤害效果(1.35)], 0, false, ["输出", "远程", "后排"])
	var 压制射击: 技能定义 = 创建技能定义(&"压制射击", "射击目标并压低其行动进度。", [2, 3, 4], [1, 2, 3, 4], 目标阵营类型.枚举.敌方单体, [创建伤害效果(0.8), 创建行动进度效果(-35.0)], 3, false, ["输出", "控速", "远程"], 1)
	var 战地包扎: 技能定义 = 创建技能定义(&"战地包扎", "为友方单体恢复生命。", [2, 3, 4], [1, 2, 3, 4], 目标阵营类型.枚举.友方单体, [创建治疗效果(0.85)], 4, false, ["治疗", "辅助"])
	var 鼓舞号令: 技能定义 = 创建技能定义(&"鼓舞号令", "稳定队伍士气，降低友方单体压力。", [2, 3, 4], [1, 2, 3, 4], 目标阵营类型.枚举.友方单体, [创建减压效果(10)], 5, false, ["辅助", "减压"], 1)
	return _创建英雄状态(编号, 敏捷值, 4.0, 6.0, [普通攻击, 精准射击, 压制射击, 战地包扎, 鼓舞号令])


static func 创建敌人定义(编号: StringName, 速度值: float) -> 敌人定义:
	var 普通攻击: 技能定义 = 创建技能定义(&"敌方普通攻击", "敌人的基础单体攻击。", [1, 2, 3, 4], [1, 2, 3, 4], 目标阵营类型.枚举.敌方单体, [创建伤害效果(1.0)], 0, true, ["基础攻击", "单体"])
	var 啃咬: 技能定义 = 创建技能定义(&"啃咬", "近身撕咬前排目标。", [1, 2], [1, 2], 目标阵营类型.枚举.敌方单体, [创建伤害效果(1.0)], 0, false, ["输出", "近战", "野兽"])
	var 扰乱扑击: 技能定义 = 创建技能定义(&"扰乱扑击", "扑向目标并打乱其节奏。", [1, 2, 3], [1, 2, 3], 目标阵营类型.枚举.敌方单体, [创建伤害效果(0.75), 创建行动进度效果(-20.0)], 2, false, ["输出", "控速", "野兽"], 1)
	var 敌人资源: 敌人定义 = 敌人定义.new()
	敌人资源.敌人编号 = 编号
	敌人资源.名称 = String(编号)
	敌人资源.基础属性 = [
		创建属性(属性类型.枚举.生命值, 50.0),
		创建属性(属性类型.枚举.速度, 速度值),
		创建属性(属性类型.枚举.力量, 4.0),
		创建属性(属性类型.枚举.智力, 2.0),
		创建属性(属性类型.枚举.护甲, 10.0),
		创建属性(属性类型.枚举.闪避率, 5.0)
	]
	敌人资源.基础行动速度 = 速度值
	敌人资源.可用技能 = [普通攻击, 啃咬, 扰乱扑击]
	return 敌人资源


static func _创建英雄状态(编号: StringName, 敏捷值: float, 力量值: float, 智力值: float, 技能列表: Array[技能定义]) -> 英雄战役状态:
	var 英雄资源: 英雄定义 = 英雄定义.new()
	英雄资源.英雄编号 = 编号
	英雄资源.名称 = String(编号)
	英雄资源.主属性类型 = 英雄主属性类型.枚举.敏捷
	英雄资源.初始行动速度 = 敏捷值
	英雄资源.基础属性 = [
		创建属性(属性类型.枚举.敏捷, 敏捷值),
		创建属性(属性类型.枚举.力量, 力量值),
		创建属性(属性类型.枚举.智力, 智力值),
		创建属性(属性类型.枚举.命中率, 15.0)
	]
	英雄资源.初始行动阈值 = 100.0
	英雄资源.初始专属技能 = 技能列表[0]
	英雄资源.可学习技能 = 技能列表
	var 英雄状态: 英雄战役状态 = 英雄战役状态.new()
	英雄状态.英雄定义资源 = 英雄资源
	英雄状态.当前等级 = 1
	英雄状态.当前装备技能 = 技能列表
	return 英雄状态


static func 创建技能定义(名称文本: StringName, 描述文本: String, 可用站位: Array, 目标站位: Array, 目标阵营: 目标阵营类型.枚举, 效果列表: Array[技能效果定义], 魔法消耗: int = 0, 是否基础攻击: bool = false, 标签: Array = [], 冷却: int = 0) -> 技能定义:
	var 技能: 技能定义 = 技能定义.new()
	技能.技能编号 = 名称文本
	技能.名称 = String(名称文本)
	技能.描述 = 描述文本
	技能.可用站位 = PackedInt32Array(可用站位)
	技能.可选目标站位 = PackedInt32Array(目标站位)
	技能.目标阵营 = 目标阵营
	技能.效果列表 = 效果列表
	技能.魔法消耗 = 魔法消耗
	技能.是否基础攻击 = 是否基础攻击
	技能.技能标签 = PackedStringArray(标签)
	技能.冷却回合 = 冷却
	return 技能


static func 创建伤害效果(系数: float) -> 技能效果定义:
	var 效果: 技能效果定义 = 技能效果定义.new()
	效果.效果类型值 = 效果类型.枚举.伤害
	效果.关联属性 = 属性类型.枚举.物理攻击力
	效果.数值系数 = 系数
	return 效果


static func 创建治疗效果(系数: float) -> 技能效果定义:
	var 效果: 技能效果定义 = 技能效果定义.new()
	效果.效果类型值 = 效果类型.枚举.治疗
	效果.关联属性 = 属性类型.枚举.力量
	效果.数值系数 = 系数
	return 效果


static func 创建位移效果(位移格数: int) -> 技能效果定义:
	var 效果: 技能效果定义 = 技能效果定义.new()
	效果.效果类型值 = 效果类型.枚举.位移
	效果.位移格数 = 位移格数
	return 效果


static func 创建行动进度效果(进度变化: float) -> 技能效果定义:
	var 效果: 技能效果定义 = 技能效果定义.new()
	效果.效果类型值 = 效果类型.枚举.行动进度变化
	效果.行动进度变化值 = 进度变化
	return 效果


static func 创建压力效果(压力值: int) -> 技能效果定义:
	var 效果: 技能效果定义 = 技能效果定义.new()
	效果.效果类型值 = 效果类型.枚举.增加压力
	效果.压力变化值 = 压力值
	return 效果


static func 创建减压效果(压力值: int) -> 技能效果定义:
	var 效果: 技能效果定义 = 技能效果定义.new()
	效果.效果类型值 = 效果类型.枚举.恢复压力
	效果.压力变化值 = 压力值
	return 效果


static func 创建属性(属性枚举: 属性类型.枚举, 数值: float) -> 属性修正定义:
	var 修正: 属性修正定义 = 属性修正定义.new()
	修正.属性 = 属性枚举
	修正.最小值 = 数值
	修正.最大值 = 数值
	return 修正
