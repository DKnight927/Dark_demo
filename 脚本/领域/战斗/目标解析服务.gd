extends RefCounted
class_name 目标解析服务


static func 解析目标(战斗状态资源: 战斗状态, 行动者: 战斗单位运行时, 意图: 行动意图) -> Array[战斗单位运行时]:
	var 结果: Array[战斗单位运行时] = []
	if 战斗状态资源 == null or 行动者 == null or 意图 == null or 意图.施放技能 == null:
		return 结果
	var 友方列表: Array[战斗单位运行时] = _取同阵营单位(战斗状态资源, 行动者)
	var 敌方列表: Array[战斗单位运行时] = _取敌对阵营单位(战斗状态资源, 行动者)
	match 意图.施放技能.目标阵营:
		目标阵营类型.枚举.自身:
			结果.append(行动者)
		目标阵营类型.枚举.友方单体, 目标阵营类型.枚举.友方群体:
			结果 = _按槽位筛选(友方列表, 意图.目标槽位列表, 意图.施放技能.目标阵营 == 目标阵营类型.枚举.友方群体)
		目标阵营类型.枚举.敌方单体, 目标阵营类型.枚举.敌方群体:
			结果 = _按槽位筛选(敌方列表, 意图.目标槽位列表, 意图.施放技能.目标阵营 == 目标阵营类型.枚举.敌方群体)
		目标阵营类型.枚举.任意单体, 目标阵营类型.枚举.任意群体:
			var 全部列表: Array[战斗单位运行时] = []
			全部列表.append_array(友方列表)
			全部列表.append_array(敌方列表)
			结果 = _按槽位筛选(全部列表, 意图.目标槽位列表, 意图.施放技能.目标阵营 == 目标阵营类型.枚举.任意群体)
	return 结果


static func _取同阵营单位(战斗状态资源: 战斗状态, 行动者: 战斗单位运行时) -> Array[战斗单位运行时]:
	if 战斗状态资源.英雄单位列表.has(行动者):
		return 战斗状态资源.英雄单位列表
	return 战斗状态资源.敌方单位列表


static func _取敌对阵营单位(战斗状态资源: 战斗状态, 行动者: 战斗单位运行时) -> Array[战斗单位运行时]:
	if 战斗状态资源.英雄单位列表.has(行动者):
		return 战斗状态资源.敌方单位列表
	return 战斗状态资源.英雄单位列表


static func _按槽位筛选(单位列表: Array[战斗单位运行时], 槽位列表: PackedInt32Array, 群体模式: bool) -> Array[战斗单位运行时]:
	var 结果: Array[战斗单位运行时] = []
	for 单位: 战斗单位运行时 in 单位列表:
		if 单位 == null or 单位.当前生命值 <= 0:
			continue
		if 群体模式 or 槽位列表.has(单位.当前槽位):
			结果.append(单位)
	return 结果