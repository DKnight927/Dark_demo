extends Node
class_name 战斗控制器

var 当前战斗状态: 战斗状态


func _处理技能冷却(单位: 战斗单位运行时, 技能: 技能定义) -> void:
	if 单位 == null or 技能 == null:
		return
	单位.推进自身技能冷却()
	单位.设置技能冷却(技能, 技能.冷却回合)


func 初始化战斗(英雄列表: Array[英雄战役状态], 敌人列表: Array[敌人定义], 敌人词缀映射: Dictionary = {}) -> 战斗状态:
	当前战斗状态 = 战斗状态.new()
	当前战斗状态.英雄单位列表 = _构建英雄单位列表(英雄列表)
	当前战斗状态.敌方单位列表 = _构建敌人单位列表(敌人列表, 敌人词缀映射)
	当前战斗状态.刷新战斗结束状态()
	return 当前战斗状态


func 推进战斗(时间增量: float) -> void:
	if 当前战斗状态 == null or 当前战斗状态.战斗是否结束:
		return
	当前战斗状态.当前时间刻度 += 时间增量
	for 单位: 战斗单位运行时 in 当前战斗状态.取全部单位():
		行动进度服务.推进单位(单位, 时间增量)
	当前战斗状态.当前可行动单位 = 行动进度服务.取可行动单位(当前战斗状态.取全部单位())
	当前战斗状态.刷新战斗结束状态()


func 取可行动单位() -> Array[战斗单位运行时]:
	if 当前战斗状态 == null:
		return []
	return 当前战斗状态.当前可行动单位


func 取单位可用技能(单位: 战斗单位运行时) -> Array[技能定义]:
	return 站位合法性服务.取可用技能(单位)


func 提交行动(单位: 战斗单位运行时, 意图: 行动意图) -> 最终行动:
	if 当前战斗状态 == null:
		return null
	if not 站位合法性服务.意图合法(单位, 意图):
		return null
	var 目标列表: Array[战斗单位运行时] = 目标解析服务.解析目标(当前战斗状态, 单位, 意图)
	var 最终结果: 最终行动 = 最终行动.new()
	最终结果.原始意图 = 意图
	最终结果.实际执行技能 = 意图.施放技能
	最终结果.最终目标槽位列表 = PackedInt32Array(_提取目标槽位(目标列表))
	if 意图.施放技能 != null and 意图.施放技能.魔法消耗 > 0:
		单位.当前魔法值 = max(单位.当前魔法值 - 意图.施放技能.魔法消耗, 0)
	最终结果.结果摘要列表 = 伤害结算服务.执行技能效果(单位, _取目标所在阵营(目标列表), 目标列表, 意图.施放技能.效果列表, 意图.施放技能)
	_处理技能冷却(单位, 意图.施放技能)
	死亡处理服务.刷新阵营死亡状态(当前战斗状态.英雄单位列表)
	死亡处理服务.刷新阵营死亡状态(当前战斗状态.敌方单位列表)
	行动进度服务.重置行动进度(单位)
	单位.当前行动进度 = 0.0
	当前战斗状态.当前可行动单位 = 行动进度服务.取可行动单位(当前战斗状态.取全部单位())
	当前战斗状态.刷新战斗结束状态()
	return 最终结果


func _取目标所在阵营(目标列表: Array[战斗单位运行时]) -> Array[战斗单位运行时]:
	if _目标列表属于英雄阵营(目标列表):
		return 当前战斗状态.英雄单位列表
	return 当前战斗状态.敌方单位列表


func _目标列表属于英雄阵营(目标列表: Array[战斗单位运行时]) -> bool:
	for 目标: 战斗单位运行时 in 目标列表:
		if 当前战斗状态.英雄单位列表.has(目标):
			return true
	return false


func _提取目标槽位(目标列表: Array[战斗单位运行时]) -> Array[int]:
	var 槽位列表: Array[int] = []
	for 目标: 战斗单位运行时 in 目标列表:
		if 目标 != null:
			槽位列表.append(目标.当前槽位)
	return 槽位列表


func _构建英雄单位列表(英雄列表: Array[英雄战役状态]) -> Array[战斗单位运行时]:
	var 结果: Array[战斗单位运行时] = []
	var 槽位: int = 1
	for 英雄状态: 英雄战役状态 in 英雄列表:
		if 英雄状态 == null:
			continue
		结果.append(战斗单位构建服务.由英雄状态构建(英雄状态, 槽位))
		槽位 += 1
	return 结果


func _构建敌人单位列表(敌人列表: Array[敌人定义], 敌人词缀映射: Dictionary) -> Array[战斗单位运行时]:
	var 结果: Array[战斗单位运行时] = []
	var 槽位: int = 1
	for 敌人资源: 敌人定义 in 敌人列表:
		if 敌人资源 == null:
			continue
		var 词缀列表: Array[怪物词缀定义] = []
		if 敌人词缀映射.has(槽位):
			词缀列表 = 敌人词缀映射[槽位]
		结果.append(战斗单位构建服务.由敌人定义构建(敌人资源, 槽位, 词缀列表))
		槽位 += 1
	return 结果
