[resource]
script = ExtResource("1")
词缀编号 = &"mo_fa_mian_yi"
名称 = "魔法免疫"
描述 = "魔法伤害固定降至极低值。实际免疫逻辑后续由词缀系统处理。"
分类 = &"immunity"
最低层级 = &"middle"
建议权重 = 8
特殊机制类型 = &"magic_immunity"
主要效果说明 = "所有魔法伤害固定为 1。"
